# Data directory (required, all runtime data: database, cookie, etc.)
DATA_DIR=./data

# Database configuration (SQLite)
DB_PATH=lark_messages.db

# Lark API configuration
# Cookie can be obtained automatically with: python main.py --login
# Or set manually:
LARK_COOKIE="YOUR LARK Cookie"

# Function trigger flag
FUNCTION_TRIGGER_FLAG="/run"

# AI Bot message prefix (preferably longer)
AI_BOT_PREFIX="Lark AI Bot:"

# OpenAI API configuration
OPENAI_API_KEY="Your api key"
OPENAI_API_BASE_URL="https://api.deepseek.com"
OPENAI_API_MODEL="deepseek-v4-pro"
